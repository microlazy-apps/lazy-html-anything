+# syntax=docker/dockerfile:1.7
+#
+# Lazycat-flavored build for nexu-io/html-anything.
+#
+# Upstream is a pnpm workspace with the Next.js app at `next/`. We bundle
+# Claude Code as the in-container coding-agent CLI plus ttyd as a /shell
+# webshell. The wrapper's responsibility is narrow:
+#
+#   1. Persistence — HOME=/lzcapp/var/persist redirects every CLI's standard
+#      dot-dir (~/.claude, ~/.codex, …) onto the lazycat bind mount, so
+#      whatever the CLI persists (credentials, sessions, config) survives
+#      upgrades and restarts.
+#   2. Access — ttyd at /shell gives the user a bash inside the container,
+#      gated by lazycat's platform auth, so they can `claude /login` /
+#      `claude config` / edit dot-files with whatever flow the CLI expects.
+#
+# We do NOT inject env vars, write a .env file, or pre-configure any CLI's
+# auth on the user's behalf. Per-CLI configuration is the CLI's own concern;
+# the wrapper just makes the result persistent.
+
+# ── builder ───────────────────────────────────────────────────────────────────
+FROM node:22-slim AS builder
+
+ENV PNPM_HOME=/pnpm
+ENV PATH=$PNPM_HOME:$PATH
+RUN corepack enable && corepack prepare pnpm@10.33.2 --activate
+
+WORKDIR /build
+
+# Workspace manifests first → maximal cache reuse on lockfile-only changes.
+COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
+COPY next/package.json ./next/
+COPY e2e/package.json ./e2e/
+
+RUN pnpm install --frozen-lockfile
+
+# Now bring in the full workspace and build.
+COPY . .
+
+# Force `output: 'standalone'` for this build without rewriting the upstream
+# config. The Next.js CLI honors NEXT_PRIVATE_STANDALONE=true at build time.
+ENV NEXT_PRIVATE_STANDALONE=true
+ENV NEXT_TELEMETRY_DISABLED=1
+RUN pnpm -F @html-anything/next build
+
+# ── runner ────────────────────────────────────────────────────────────────────
+FROM node:22-slim AS runner
+
+# Runtime deps:
+#   curl       — lazycat healthcheck probes
+#   tini       — reap claude-code's many child processes (git/rg/node/…)
+#   supervisor — keep `next` and `ttyd` alive in the same container
+#   nano,vim-tiny — friendly editors for the webshell user
+#   bash       — already present, but listed for intent (ttyd shells out to it)
+RUN apt-get update \
+ && apt-get install -y --no-install-recommends \
+      curl tini ca-certificates \
+      supervisor nano vim-tiny bash \
+ && rm -rf /var/lib/apt/lists/*
+
+# ttyd static binary (statically linked, version pinned). Serves the
+# /shell webshell — that's the user's only door for per-CLI config
+# (`claude /login`, `claude config set ...`, etc.).
+ARG TTYD_VERSION=1.7.7
+ARG TARGETARCH
+RUN ARCH=$([ "${TARGETARCH:-amd64}" = "arm64" ] && echo aarch64 || echo x86_64) \
+ && curl -fsSL "https://github.com/tsl0922/ttyd/releases/download/${TTYD_VERSION}/ttyd.${ARCH}" \
+      -o /usr/local/bin/ttyd \
+ && chmod +x /usr/local/bin/ttyd \
+ && /usr/local/bin/ttyd --version
+
+# Claude Code is the bundled coding-agent CLI. Auth is the user's
+# responsibility — they `claude /login` (or whatever) inside the /shell
+# webshell, and Claude Code writes credentials into ~/.claude/ which is
+# the persisted HOME.
+RUN npm install -g @anthropic-ai/claude-code@latest \
+ && npm cache clean --force
+
+WORKDIR /app
+
+# Next.js standalone output is rooted at `next/.next/standalone/`. Inside it,
+# the workspace tree is preserved, so the launchable entrypoint is
+# `next/.next/standalone/next/server.js`. We mirror that layout under /app.
+COPY --from=builder /build/next/.next/standalone ./
+COPY --from=builder /build/next/.next/static       ./next/.next/static
+COPY --from=builder /build/next/public             ./next/public
+# Skill registry reads templates from process.cwd() + 'src/lib/templates/skills'.
+# Standalone tracing drops the source tree, so we restore the templates dir.
+COPY --from=builder /build/next/src/lib/templates  ./next/src/lib/templates
+
+COPY lazycat-entrypoint.sh /usr/local/bin/lazycat-entrypoint.sh
+COPY supervisord.conf      /etc/supervisor/supervisord.conf
+RUN chmod +x /usr/local/bin/lazycat-entrypoint.sh
+
+ENV NODE_ENV=production
+ENV NEXT_TELEMETRY_DISABLED=1
+ENV PORT=3000
+ENV HOSTNAME=0.0.0.0
+# HOME → persisted volume so Claude Code's ~/.claude state and html-anything's
+# ~/.html-anything state survive container restarts; the webshell user lands
+# in this directory too.
+ENV HOME=/lzcapp/var/persist
+# Tell Claude Code it's running inside an isolated sandbox so it skips the
+# "refuse to bypassPermissions under root" check. We are root in the
+# container by necessity (lazycat doesn't preserve UID on the persist
+# bind), and html-anything's argv.ts always passes
+# `--permission-mode bypassPermissions` — without this env, every spawn
+# would fail with "cannot be used with root/sudo privileges".
+ENV IS_SANDBOX=1
+
+# 3000 = Next.js;  7681 = ttyd. Both proxied through lazycat (see manifest).
+EXPOSE 3000 7681
+
+ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/lazycat-entrypoint.sh"]
