@@ -0,0 +1,35 @@
+#!/usr/bin/env bash
+# Lazycat-flavored entrypoint for html-anything.
+#
+# The wrapper owns *persistence* (HOME → /lzcapp/var/persist) and *access*
+# (ttyd /shell webshell). It does NOT own per-CLI configuration: each CLI
+# (claude / codex / cursor-agent / …) uses its own auth flow and writes
+# to its own dot-dir under $HOME. Because $HOME is bind-mounted to a
+# lazycat persistent volume, anything those CLIs persist (credentials,
+# settings, sessions) survives upgrades and restarts.
+#
+# So the typical first-time setup is:
+#   1. Open https://html-anything.<box-domain>/shell/
+#   2. Run `claude /login` (OAuth) — credentials land in ~/.claude/.credentials.json
+#      Or configure an API key per Claude Code's own docs (apiKeyHelper, env, …)
+#   3. Back to the main UI, prompt away.
+
+set -euo pipefail
+
+: "${HOME:=/lzcapp/var/persist}"
+export HOME
+
+# Ensure the persistent dot-dirs exist so each CLI / app can write without
+# having to mkdir on first use. We don't seed any files here — that's each
+# CLI's responsibility.
+mkdir -p \
+  "${HOME}/.claude" \
+  "${HOME}/.html-anything/skills"
+
+# Skip Claude Code's interactive onboarding wizard inside the container —
+# the wizard expects a TTY; we want one-shot CLI invocations from Next.js.
+export DISABLE_AUTOUPDATER=1
+export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
+
+# Hand off to supervisord, which keeps `next` and `ttyd` alive in parallel.
+exec /usr/bin/supervisord -c /etc/supervisor/supervisord.conf
diff --git a/supervisord.conf b/supervisord.conf
new file mode 100644
index 0000000..6935597
--- /dev/null
+++ b/supervisord.conf
@@ -0,0 +1,64 @@
+; Supervisor config — keep Next.js and ttyd alive in parallel.
+; All output streams to stdout/stderr so `docker logs` / lazycat shows them.
+
+[supervisord]
+nodaemon=true
+user=root
+logfile=/dev/stdout
+logfile_maxbytes=0
+pidfile=/run/supervisord.pid
+
+[unix_http_server]
+file=/run/supervisor.sock
+
+[supervisorctl]
+serverurl=unix:///run/supervisor.sock
+
+[rpcinterface:supervisor]
+supervisor.rpcinterface_factory = supervisor.rpcinterface:make_main_rpcinterface
+
+; ── Next.js standalone server ─────────────────────────────────────────────────
+;
+; Started from /app/next so process.cwd() matches what
+; next/src/lib/templates/loader.ts expects (it joins cwd + 'src/lib/templates/skills').
+[program:next]
+command=/usr/local/bin/node server.js
+directory=/app/next
+autostart=true
+autorestart=true
+startsecs=5
+stopsignal=TERM
+stopwaitsecs=15
+stdout_logfile=/dev/stdout
+stdout_logfile_maxbytes=0
+stderr_logfile=/dev/stderr
+stderr_logfile_maxbytes=0
+
+; ── ttyd webshell ─────────────────────────────────────────────────────────────
+;
+; Served at /shell behind lazycat's reverse-proxy + platform auth (only
+; logged-in lazycat users on the same box reach this subdomain).
+;
+; Flags:
+;   --writable          allow keyboard input (default is read-only)
+;   --port 7681         lazycat manifest reverse-proxies /shell/ → main:7681
+;   --max-clients 4     cheap DOS guard
+;
+; NO --base-path: lazycat strips the /shell/ prefix before forwarding, so
+; ttyd sees /, /token, /ws and serves them from root. Re-adding
+; --base-path would make ttyd 404 the stripped paths.
+;
+; bash starts in $HOME (lazycat persist bind), so users land right where
+; their CLI config dirs live.
+[program:ttyd]
+command=/usr/local/bin/ttyd --writable --port 7681 --max-clients 4 bash
+directory=%(ENV_HOME)s
+autostart=true
+autorestart=true
+startsecs=3
+stopsignal=TERM
+stopwaitsecs=5
+stdout_logfile=/dev/stdout
+stdout_logfile_maxbytes=0
+stderr_logfile=/dev/stderr
+stderr_logfile_maxbytes=0
